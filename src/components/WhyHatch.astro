---
import type { Locale } from '../i18n/ui';
import type { CollectionEntry } from 'astro:content';
import { Jay } from './birds/Birds.tsx';

interface Props {
  locale: Locale;
  data: CollectionEntry<'landing'>['data']['why'];
}

const { data } = Astro.props;
---

<section
  class="pourquoi-sec overflow-hidden border-t border-slate-100 bg-white pt-14 pb-4"
  id="pourquoi"
>
  <div class="container-site">
    <div class="pourquoi-inner grid items-start gap-[72px] md:grid-cols-2">
      <div class="pourquoi-left max-w-[480px]">
        <div
          class="pourquoi-pill mb-5 inline-flex items-center gap-[7px] rounded-full border border-orange-200 bg-orange-50 px-3.5 py-[5px] text-xs font-semibold tracking-[0.04em] text-orange-700"
        >
          <span class="pourquoi-pill-dot h-1.5 w-1.5 rounded-full bg-hatch-accent"></span>
          <span>{data.pillLabel}</span>
        </div>

        <h2
          class="pourquoi-h2 mb-4 font-display text-[40px] font-normal leading-[1.15] tracking-[-0.02em] text-slate-900"
          set:html={data.h2}
        />

        <div class="pq-features mt-10 space-y-5">
          <div class="pq-feature flex items-start gap-3">
            <div
              class="pq-feature-dot mt-1.5 h-2 w-2 flex-shrink-0 rounded-full"
              style="background:#1a4227"
            >
            </div>
            <div class="text-[14.5px] leading-[1.65] text-slate-600" set:html={data.feat1} />
          </div>
          <div class="pq-feature flex items-start gap-3">
            <div
              class="pq-feature-dot mt-1.5 h-2 w-2 flex-shrink-0 rounded-full"
              style="background:#1a4227"
            >
            </div>
            <div class="text-[14.5px] leading-[1.65] text-slate-600" set:html={data.feat2} />
          </div>
          <div class="pq-feature flex items-start gap-3">
            <div
              class="pq-feature-dot mt-1.5 h-2 w-2 flex-shrink-0 rounded-full"
              style="background:#1a4227"
            >
            </div>
            <div class="text-[14.5px] leading-[1.65] text-slate-600" set:html={data.feat3} />
          </div>
        </div>
      </div>

      <!-- RIGHT — floating mockup cards -->
      <div class="pourquoi-right relative h-[620px] md:h-[620px]">
        <!-- Card 1 — WhatsApp chat -->
        <div
          class="pq-card pq-card-chat absolute right-0 top-[120px] z-[4] w-[260px] max-h-[320px] overflow-hidden rounded-2xl bg-white"
          style="box-shadow: var(--shadow-pq-card); animation: pqFloat1 6s ease-in-out infinite; animation-delay: -1s;"
        >
          <div class="pq-wa-header flex items-center gap-2.5 bg-wa-dark px-3.5 py-2.5 text-white">
            <div
              class="pq-wa-avatar flex h-[30px] w-[30px] flex-shrink-0 items-center justify-center overflow-hidden rounded-full bg-amber-50 p-[3px]"
            >
              <img
                src="/logos/peep-avatar.png"
                alt="Peep"
                class="h-full w-full rounded-full object-contain"
              />
            </div>
            <div>
              <div class="pq-wa-name text-[12.5px] font-semibold leading-tight">{data.waName}</div>
              <div class="pq-wa-status text-[9.5px] opacity-70">{data.waStatus}</div>
            </div>
          </div>
          <div class="pq-wa-body pq-wa-dark relative flex flex-col gap-1.5 px-3 py-2.5">
            <div
              class="pq-wa-date mx-auto w-fit rounded-md px-2 py-[3px] text-center text-[9px] text-slate-400"
              style="background:#1d2b32;"
            >
              {data.waDate}
            </div>
            <div
              class="pq-wa-meta px-2.5 py-1.5 text-center text-[9px] leading-[1.5] text-wa-green"
            >
              {data.waMeta}
            </div>
            <div
              class="pq-msg recv max-w-[88%] self-start rounded-r-lg rounded-bl-lg px-2.5 py-1.5 text-[11px] leading-[1.5] text-slate-100"
              style="background:#202c33;"
              set:html={data.waMsg}
            />
            <div
              class="pq-msg recv mt-1 max-w-[88%] self-start rounded-r-lg rounded-bl-lg px-2.5 py-1.5 text-[11px] leading-[1.5] text-slate-100"
              style="background:#202c33;"
            >
              <span>{data.waCtaTxt}</span>
              <div class="pq-msg-time text-right text-[8.5px] text-slate-400">14:53</div>
              <div
                class="pq-wa-btn mt-2 rounded-md border border-slate-700 px-3 py-1.5 text-center text-[10px] font-semibold"
                style="background:#2a3942;color:#00a884;"
              >
                {data.waBtn}
              </div>
            </div>
          </div>
        </div>

        <!-- Card 2 — Jay documentation interface -->
        <div
          class="pq-card pq-card-report absolute left-0 top-0 z-[3] w-[268px] max-h-[220px] overflow-hidden rounded-2xl"
          style="box-shadow: var(--shadow-pq-card); animation: pqFloat2 6s ease-in-out infinite; animation-delay: -2s;"
        >
          <div class="pq-jay-body p-4 pt-[18px] pb-3.5" style="background:#f0ede8;">
            <div class="pq-jay-top mb-3.5 flex items-center gap-2.5">
              <div class="pq-jay-avatar flex h-11 w-11 flex-shrink-0 items-center justify-center">
                <Jay size={44} showLabel={false} feet={false} />
              </div>
              <div
                class="pq-jay-greeting font-display text-[11px] leading-[1.5]"
                style="color:#1a1a1a;"
                set:html={data.jayGreeting}
              />
            </div>
            <div class="pq-jay-chips mb-3 grid grid-cols-2 gap-1.5">
              <div
                class="pq-jay-chip flex items-center gap-1 rounded-lg bg-white px-2 py-1.5 text-[9px] text-slate-700 shadow-[0_1px_3px_rgba(0,0,0,0.07)]"
              >
                <span class="pq-jay-chip-icon text-[9px] opacity-60">🔍</span>
                <span set:html={data.chip1} />
              </div>
              <div
                class="pq-jay-chip flex items-center gap-1 rounded-lg bg-white px-2 py-1.5 text-[9px] text-slate-700 shadow-[0_1px_3px_rgba(0,0,0,0.07)]"
              >
                <span class="pq-jay-chip-icon text-[9px] opacity-60">📋</span>
                <span set:html={data.chip2} />
              </div>
              <div
                class="pq-jay-chip flex items-center gap-1 rounded-lg bg-white px-2 py-1.5 text-[9px] text-slate-700 shadow-[0_1px_3px_rgba(0,0,0,0.07)]"
              >
                <span class="pq-jay-chip-icon text-[9px] opacity-60">🔍</span>
                <span set:html={data.chip3} />
              </div>
              <div
                class="pq-jay-chip flex items-center gap-1 rounded-lg bg-white px-2 py-1.5 text-[9px] text-slate-700 shadow-[0_1px_3px_rgba(0,0,0,0.07)]"
              >
                <span class="pq-jay-chip-icon text-[9px] opacity-60">📄</span>
                <span set:html={data.chip4} />
              </div>
            </div>
            <div
              class="pq-jay-input mb-2 flex items-center justify-between rounded-[10px] bg-white px-2.5 py-2 shadow-[0_2px_8px_rgba(0,0,0,0.08)]"
            >
              <span class="pq-jay-placeholder text-[9.5px] text-slate-400"
                >{data.jayPlaceholder}</span
              >
              <div
                class="pq-jay-send flex h-[22px] w-[22px] items-center justify-center rounded-md text-[9px] text-white"
                style="background:#e8a87c;"
              >
                ➤
              </div>
            </div>
            <div class="pq-jay-hint text-center text-[8px] text-slate-400">{data.jayHint}</div>
          </div>
        </div>

        <!-- Card 3 — Pipeline -->
        <div
          class="pq-card pq-card-pipe absolute left-2.5 top-[310px] z-[2] w-[248px] max-h-[200px] overflow-hidden rounded-2xl"
          style="box-shadow: var(--shadow-pq-card); animation: pqFloat3 6s ease-in-out infinite; animation-delay: -4s;"
        >
          <div
            class="pq-pipe-header border-b px-3.5 py-2.5"
            style="background:#f5f3ef;border-color:#ebe8e2;"
          >
            <div
              class="pq-pipe-title text-[11px] font-bold tracking-[0.01em]"
              style="color:#1a1a1a;"
            >
              {data.pipeTitle}
            </div>
            <div class="pq-pipe-sub mt-0.5 text-[9px]" style="color:#6a6258;">{data.pipeSub}</div>
          </div>
          <div class="pq-pipe-body flex flex-col gap-2.5 p-3" style="background:#f5f3ef;">
            <div class="pq-pipe-phase flex flex-col gap-1">
              <div
                class="pq-pipe-phase-label text-[8px] font-bold uppercase tracking-[0.07em]"
                style="color:#b0a898;"
              >
                {data.pipePhase1}
              </div>
              <div
                class="pq-pipe-stage flex items-center gap-[7px] rounded-lg bg-white px-2.5 py-1.5 text-[10.5px] text-slate-900 shadow-[0_1px_4px_rgba(0,0,0,0.07)]"
              >
                <span
                  class="pq-pipe-dot h-[9px] w-[9px] flex-shrink-0 rounded-full bg-hatch-accent-soft"
                ></span>
                <span>{data.pipeStage1}</span>
                <span
                  class="pq-pipe-count ml-auto rounded px-1.5 py-px text-[9px] font-semibold"
                  style="background:#f5f3ef;color:#a0998e;">0</span
                >
              </div>
            </div>
            <div class="pq-pipe-phase flex flex-col gap-1">
              <div
                class="pq-pipe-phase-label text-[8px] font-bold uppercase tracking-[0.07em]"
                style="color:#b0a898;"
              >
                {data.pipePhase2}
              </div>
              <div
                class="pq-pipe-stage flex items-center gap-[7px] rounded-lg bg-white px-2.5 py-1.5 text-[10.5px] text-slate-900 shadow-[0_1px_4px_rgba(0,0,0,0.07)]"
              >
                <span
                  class="pq-pipe-dot h-[9px] w-[9px] flex-shrink-0 rounded-full bg-hatch-accent-soft"
                ></span>
                <span>{data.pipeStage2}</span>
                <span
                  class="pq-pipe-count ml-auto rounded px-1.5 py-px text-[9px] font-semibold"
                  style="background:#f5f3ef;color:#a0998e;">0</span
                >
              </div>
            </div>
            <div class="pq-pipe-phase flex flex-col gap-1">
              <div
                class="pq-pipe-phase-label text-[8px] font-bold uppercase tracking-[0.07em]"
                style="color:#b0a898;"
              >
                {data.pipePhase3}
              </div>
              <div class="pq-pipe-stage empty pl-0.5 text-[9px] italic" style="color:#c0b8ae;">
                <em>{data.pipeEmpty}</em>
              </div>
            </div>
            <div class="pq-pipe-phase flex flex-col gap-1">
              <div
                class="pq-pipe-phase-label text-[8px] font-bold uppercase tracking-[0.07em]"
                style="color:#b0a898;"
              >
                {data.pipePhase4}
              </div>
              <div class="pq-pipe-stage empty pl-0.5 text-[9px] italic" style="color:#c0b8ae;">
                <em>{data.pipeEmpty}</em>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Card-specific transforms (the keyframes themselves are global). */
  .pq-card-chat {
    transform: rotate(-2deg);
  }
  .pq-card-report {
    transform: rotate(2deg);
  }
  .pq-card-pipe {
    transform: rotate(1deg);
  }

  /* Mobile: stack cards vertically (override keyframes via positioning). */
  @media (max-width: 640px) {
    .pourquoi-right {
      position: static !important;
      height: auto !important;
      display: flex;
      flex-direction: column;
      gap: 16px;
    }
    .pourquoi-right .pq-card {
      position: static !important;
      width: 100% !important;
      max-width: 100% !important;
      max-height: none !important;
      transform: none !important;
      animation: none !important;
    }
  }
</style>
