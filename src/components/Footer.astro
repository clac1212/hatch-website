---
import type { CollectionEntry } from 'astro:content';
import HatchLogo from './HatchLogo.astro';

interface Props {
  data: CollectionEntry<'landing'>['data']['footer'];
}

const { data } = Astro.props;
---

<footer class="px-0 py-8 pb-12" style="background: var(--footer-gradient);">
  <div
    class="footer-inner container-site flex flex-wrap items-end justify-between gap-5 md:flex-row"
  >
    <div class="flex flex-col gap-2">
      <HatchLogo size={36} class="rounded-lg" />
      <div class="footer-tagline text-xs text-white/55">{data.tagline}</div>
    </div>
    <div class="footer-copy text-xs text-white/55">{data.copyright}</div>
  </div>
</footer>
