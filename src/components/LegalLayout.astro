---
import type { Locale } from '../i18n/ui';
import '../styles/global.css';

interface Props {
  locale: Locale;
  title: string;
  description?: string;
}

const { locale, title, description = title } = Astro.props;
const homeUrl = locale === 'en' ? '/en/' : '/';
const privacyUrl = locale === 'en' ? '/en/privacy' : '/privacy';
const termsUrl = locale === 'en' ? '/en/terms' : '/terms';
const backLabel = locale === 'en' ? 'Back to site' : 'Retour au site';
const copyrightText = '© 2026 Hatch · gethatch.io';
const privacyLabel = locale === 'en' ? 'Privacy' : 'Confidentialité';
const termsLabel = locale === 'en' ? 'Terms' : 'CGU';
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400..700;1,9..144,400..600&family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <style>
      .legal-nav {
        position: fixed;
        top: 0; left: 0; right: 0;
        z-index: 100;
        background: rgba(5, 19, 9, 0.88);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border-bottom: 1px solid rgba(255, 255, 255, 0.07);
      }
      .legal-back {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 14px;
        font-weight: 500;
        color: rgba(255, 255, 255, 0.5);
        transition: color 0.15s;
      }
      .legal-back:hover { color: #fff; }
      .legal-back svg { transition: transform 0.15s; }
      .legal-back:hover svg { transform: translateX(-3px); }
      .legal-footer-link {
        font-size: 13px;
        color: rgba(255, 255, 255, 0.35);
        transition: color 0.15s;
      }
      .legal-footer-link:hover { color: rgba(255, 255, 255, 0.7); }
      /* Typography */
      .legal-content h1 {
        font-family: 'Fraunces', Georgia, serif;
        font-size: clamp(30px, 4vw, 44px);
        font-weight: 700;
        line-height: 1.1;
        letter-spacing: -0.02em;
        color: #0f1f10;
        margin-bottom: 12px;
      }
      .legal-content .meta {
        font-size: 13px;
        color: #6b8572;
        margin-bottom: 48px;
      }
      .legal-content h2 {
        font-family: 'Fraunces', Georgia, serif;
        font-size: 22px;
        font-weight: 700;
        color: #0f1f10;
        letter-spacing: -0.015em;
        margin-top: 44px;
        margin-bottom: 14px;
      }
      .legal-content h3 {
        font-family: 'Inter', sans-serif;
        font-size: 15px;
        font-weight: 700;
        color: #0f1f10;
        margin-top: 24px;
        margin-bottom: 10px;
      }
      .legal-content p {
        font-size: 15px;
        color: #374151;
        line-height: 1.75;
        margin-bottom: 14px;
      }
      .legal-content ul {
        margin: 10px 0 16px 0;
        padding-left: 22px;
        list-style: disc;
      }
      .legal-content ul li {
        font-size: 15px;
        color: #374151;
        line-height: 1.7;
        margin-bottom: 6px;
      }
      .legal-content a {
        color: #386641;
        text-decoration: underline;
        text-underline-offset: 2px;
      }
      .legal-content a:hover { color: #ea580c; }
      .legal-table-wrap {
        overflow-x: auto;
        margin: 16px 0 24px;
        border-radius: 10px;
        border: 1px solid #e5e7eb;
      }
      .legal-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 14px;
      }
      .legal-table th {
        background: #f9fafb;
        text-align: left;
        padding: 10px 16px;
        font-weight: 600;
        color: #374151;
        border-bottom: 1px solid #e5e7eb;
      }
      .legal-table td {
        padding: 10px 16px;
        color: #4b5563;
        border-bottom: 1px solid #f3f4f6;
        vertical-align: top;
      }
      .legal-table tr:last-child td { border-bottom: none; }
      .legal-divider {
        border: none;
        border-top: 1px solid #e5e7eb;
        margin: 48px 0;
      }
    </style>
  </head>
  <body class="bg-white">
    <!-- NAV -->
    <nav class="legal-nav">
      <div
        style="display:flex;align-items:center;justify-content:space-between;height:64px;max-width:1120px;margin:0 auto;padding:0 32px;"
      >
        <a href={homeUrl} aria-label="Hatch">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="280 270 520 560"
            width="30"
            height="30"
            style="display:block;border-radius:7px;"
            aria-hidden="true"
          >
            <rect fill="#ea580c" x="0" y="0" width="1080" height="1080" rx="80"></rect>
            <path
              fill="#fff4a4"
              d="M518.89,659.49V607.25l-38.18,11.3-39.32-27.47v68.41c0,16.44-19.17,17.25-19.17,31.21,0,12.72,11.75,14.36,26.12,14.36h63.15c14.82,0,26.57-1.64,26.57-14.36C538.06,676.74,518.89,675.93,518.89,659.49Z"
            ></path>
            <path
              fill="#fff4a4"
              d="M656.06,659.49V587.67c0-7.23-.27-14.14-.9-20.69L578,589.79c.1,2.23.14,4.52.14,6.93v62.77c0,16.44-19.17,17.25-19.17,31.62,0,12.31,12.19,13.95,26.57,13.95h63.15c14.37,0,26.57-1.64,26.57-13.95C675.24,676.74,656.06,675.93,656.06,659.49Z"
            ></path>
            <path
              fill="#fff4a4"
              d="M575.43,469.79c-33,2.2-54.49,20.63-66.44,44.57l-2.18.14L499,396.32c-1-15.64-6.26-22.29-21.49-21.28-22.57,1.5-73.67,20.6-72.69,35.39.66,10,7.78,12.14,16.44,17.68,5.9,3.53,11.09,9.3,12.07,24.06l8.93,115.63,39.16,28,36.47-13.4-.19-3c-1.79-26.93,7.76-47.79,29-49.21,16.38-1.09,25.46,9.35,29.66,29.86l75-29.09C642.27,490.47,620.26,466.82,575.43,469.79Z"
            ></path>
          </svg>
        </a>
        <a href={homeUrl} class="legal-back">
          <svg
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
          >
            <path d="M19 12H5M12 5l-7 7 7 7"></path>
          </svg>
          <span>{backLabel}</span>
        </a>
      </div>
    </nav>

    <!-- CONTENT -->
    <main style="padding-top: 96px; padding-bottom: 80px;">
      <div style="max-width: 760px; margin: 0 auto; padding: 0 24px;" class="legal-content">
        <slot />
      </div>
    </main>

    <!-- FOOTER -->
    <footer style="background: var(--footer-gradient); border-top: 1px solid rgba(255,255,255,0.06);">
      <div
        style="max-width:1120px;margin:0 auto;padding:24px 32px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;"
      >
        <span style="font-size:13px;color:rgba(255,255,255,0.3);">{copyrightText}</span>
        <div style="display:flex;align-items:center;gap:20px;">
          <a href={privacyUrl} class="legal-footer-link">{privacyLabel}</a>
          <a href={termsUrl} class="legal-footer-link">{termsLabel}</a>
        </div>
      </div>
    </footer>
  </body>
</html>
