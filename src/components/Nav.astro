---
import { ui, demoUrl, type Locale } from '../i18n/ui';
import type { CollectionEntry } from 'astro:content';

interface Props {
  locale: Locale;
  data: CollectionEntry<'landing'>['data']['nav'];
}

const { locale, data } = Astro.props;
const t = ui[locale];
const otherLocale: Locale = locale === 'fr' ? 'en' : 'fr';
const otherLocaleUrl = otherLocale === 'fr' ? '/' : '/en/';
---

<nav>
  <div class="nav-inner mx-auto flex h-16 max-w-[1120px] items-center justify-between px-8 md:px-8">
    <a href={locale === 'fr' ? '/' : '/en/'} class="logo flex items-center" aria-label="Hatch">
      <img
        class="logo-img logo-img-light block h-7 w-auto"
        src="/logos/hatch-light.png"
        alt="Hatch"
        style="filter: brightness(0) saturate(100%) invert(50%) sepia(100%) saturate(380%) hue-rotate(348deg) brightness(91%);"
      />
      <img
        class="logo-img logo-img-dark hidden h-7 w-auto"
        src="/logos/hatch-dark.png"
        alt="Hatch"
      />
    </a>

    <ul class="nav-links hidden gap-8 md:flex" aria-label={t.ariaLabels.primaryNav}>
      <li>
        <a class="nav-link text-sm font-medium transition" href="#pourquoi">{data.why}</a>
      </li>
      <li>
        <a class="nav-link text-sm font-medium transition" href="#agents">{data.product}</a>
      </li>
      <li>
        <a class="nav-link text-sm font-medium transition" href="#pricing">{data.pricing}</a>
      </li>
      <li>
        <a class="nav-link text-sm font-medium transition" href="#faq">{data.faq}</a>
      </li>
    </ul>

    <div class="nav-right flex items-center gap-2.5">
      <div
        class="lang-switcher flex items-center gap-[3px] rounded-lg p-[3px] transition"
        role="group"
        aria-label={t.languageSwitcher.ariaLabel}
      >
        <a
          href="/"
          class:list={[
            'lang-btn rounded-md border-none px-2.5 py-1 text-[11px] font-bold tracking-[0.08em] transition',
            locale === 'fr' && 'active shadow-[0_1px_4px_rgba(0,0,0,0.12)]',
          ]}
        >
          {t.languageSwitcher.fr}
        </a>
        <a
          href="/en/"
          class:list={[
            'lang-btn rounded-md border-none px-2.5 py-1 text-[11px] font-bold tracking-[0.08em] transition',
            locale === 'en' && 'active shadow-[0_1px_4px_rgba(0,0,0,0.12)]',
          ]}
        >
          {t.languageSwitcher.en}
        </a>
      </div>
<a
        href={demoUrl(locale)}
        id="nav-btn-demo"
        class="btn-primary hidden items-center gap-[7px] whitespace-nowrap rounded-[9px] bg-hatch-cta px-5 py-2.5 text-sm font-semibold text-hatch-text transition hover:-translate-y-px hover:bg-hatch-cta-hover hover:shadow-[0_6px_22px_rgba(255,244,164,0.28)] sm:inline-flex"
      >
        {t.nav.demo}
      </a>
    </div>
  </div>
</nav>

<script is:inline>
  // Sticky nav: adds .scrolled past 60px, uses getBoundingClientRect on
  // actual sections to decide dark/light theme — avoids hitting nav itself.
  const DARK_SECTIONS = ['hero', 'agents', 'agents-section'];

  const navEl = document.querySelector('nav');
  if (navEl) {
    const updateNavTheme = () => {
      if (!navEl.classList.contains('scrolled')) {
        navEl.classList.remove('nav-on-light');
        return;
      }
      const probeY = 32;
      const sections = document.querySelectorAll('section');
      for (const section of sections) {
        const rect = section.getBoundingClientRect();
        if (rect.top <= probeY && rect.bottom > probeY) {
          const id = section.id || '';
          const cls = section.className || '';
          const isDark = DARK_SECTIONS.includes(id) || DARK_SECTIONS.some((d) => cls.includes(d));
          navEl.classList.toggle('nav-on-light', !isDark);
          return;
        }
      }
      navEl.classList.remove('nav-on-light');
    };

    const onScroll = () => {
      if (window.scrollY > 60) {
        navEl.classList.add('scrolled');
      } else {
        navEl.classList.remove('scrolled');
        navEl.classList.remove('nav-on-light');
      }
      updateNavTheme();
    };

    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('load', onScroll);
    onScroll();
  }
</script>
