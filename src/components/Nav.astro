---
import { ui, externalUrls, type Locale } from '../i18n/ui';
import type { CollectionEntry } from 'astro:content';

interface Props {
  locale: Locale;
  data: CollectionEntry<'landing'>['data']['nav'];
}

const { locale, data } = Astro.props;
const t = ui[locale];
const otherLocale: Locale = locale === 'fr' ? 'en' : 'fr';
const otherLocaleUrl = otherLocale === 'fr' ? '/' : '/en/';
---

<nav>
  <div class="nav-inner mx-auto flex h-16 max-w-[1120px] items-center justify-between px-8 md:px-8">
    <a href={locale === 'fr' ? '/' : '/en/'} class="logo flex items-center" aria-label="Hatch">
      <img
        class="logo-img logo-img-light block h-7 w-auto"
        src="/logos/hatch-light.png"
        alt="Hatch"
      />
      <img
        class="logo-img logo-img-dark hidden h-7 w-auto"
        src="/logos/hatch-dark.png"
        alt="Hatch"
      />
    </a>

    <ul class="nav-links hidden gap-8 md:flex" aria-label={t.ariaLabels.primaryNav}>
      <li>
        <a
          class="nav-link text-sm font-medium text-white/85 transition hover:text-white"
          href="#pourquoi"
        >
          {data.why}
        </a>
      </li>
      <li>
        <a
          class="nav-link text-sm font-medium text-white/85 transition hover:text-white"
          href="#agents"
        >
          {data.product}
        </a>
      </li>
      <li>
        <a
          class="nav-link text-sm font-medium text-white/85 transition hover:text-white"
          href="#pricing"
        >
          {data.pricing}
        </a>
      </li>
      <li>
        <a
          class="nav-link text-sm font-medium text-white/85 transition hover:text-white"
          href="#faq"
        >
          {data.faq}
        </a>
      </li>
    </ul>

    <div class="nav-right flex items-center gap-2.5">
      <div
        class="lang-switcher flex items-center gap-[3px] rounded-lg bg-white/10 p-[3px] transition"
        role="group"
        aria-label={t.languageSwitcher.ariaLabel}
      >
        <a
          href="/"
          class:list={[
            'lang-btn rounded-md border-none bg-transparent px-2.5 py-1 text-[11px] font-bold tracking-[0.08em] text-white/70 transition',
            locale === 'fr' && 'active bg-white/15 text-white shadow-[0_1px_4px_rgba(0,0,0,0.12)]',
          ]}
        >
          {t.languageSwitcher.fr}
        </a>
        <a
          href="/en/"
          class:list={[
            'lang-btn rounded-md border-none bg-transparent px-2.5 py-1 text-[11px] font-bold tracking-[0.08em] text-white/70 transition',
            locale === 'en' && 'active bg-white/15 text-white shadow-[0_1px_4px_rgba(0,0,0,0.12)]',
          ]}
        >
          {t.languageSwitcher.en}
        </a>
      </div>
      <a
        href={externalUrls.login}
        id="nav-btn-login"
        class="btn-ghost hidden items-center gap-[7px] whitespace-nowrap rounded-[9px] border-[1.5px] border-white/30 bg-transparent px-[18px] py-2.5 text-sm font-semibold text-white/95 transition hover:border-white/60 hover:bg-white/10 hover:text-white sm:inline-flex"
      >
        {t.nav.login}
      </a>
      <a
        href={externalUrls.demoForm}
        id="nav-btn-demo"
        target="_blank"
        rel="noopener"
        class="btn-primary hidden items-center gap-[7px] whitespace-nowrap rounded-[9px] bg-hatch-cta px-5 py-2.5 text-sm font-semibold text-hatch-text transition hover:-translate-y-px hover:bg-hatch-cta-hover hover:shadow-[0_6px_22px_rgba(255,244,164,0.28)] sm:inline-flex"
      >
        {t.nav.demo}
      </a>
    </div>
  </div>
</nav>

<script>
  // Sticky nav behavior — adds .scrolled when past 60px, then probes the
  // element under the nav at y=32 to decide if we're over a "dark section"
  // (in which case nav stays dark) or a "light section" (nav goes light).
  const DARK_SECTIONS = ['hero', 'agents', 'agents-section'];

  const navEl = document.querySelector('nav');
  if (navEl) {
    const updateNavTheme = () => {
      const probe = document.elementFromPoint(window.innerWidth / 2, 32);
      if (!probe) return;
      const section = probe.closest('section, footer, nav');
      const id = section?.id || '';
      const cls = section?.className || '';
      const isDark =
        DARK_SECTIONS.includes(id) ||
        DARK_SECTIONS.some((d) => (typeof cls === 'string' ? cls.includes(d) : false)) ||
        section?.tagName === 'FOOTER';
      navEl.classList.toggle('nav-on-light', !isDark);
    };

    const onScroll = () => {
      if (window.scrollY > 60) {
        navEl.classList.add('scrolled');
      } else {
        navEl.classList.remove('scrolled');
      }
      updateNavTheme();
    };

    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }
</script>
