---
import { getEntry, getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import WhyHatch from '../components/WhyHatch.astro';
import HowItWorks from '../components/HowItWorks.astro';
import HubDiagram from '../components/HubDiagram.astro';
import Agents from '../components/Agents.astro';
import Pricing from '../components/Pricing.astro';
import FAQ from '../components/FAQ.astro';
import Footer from '../components/Footer.astro';

const locale = 'fr' as const;
const landing = await getEntry('landing', locale);
if (!landing) throw new Error('Missing landing/fr content collection entry.');

const agents = await getCollection('agents');
const { data } = landing;
---

<Base title={data.title} description={data.description} locale={locale}>
  <Nav locale={locale} data={data.nav} />
  <Hero locale={locale} data={data.hero} />
  <WhyHatch locale={locale} data={data.why} />
  <HowItWorks locale={locale} data={data.hiw} />
  <HubDiagram locale={locale} data={data.hub} />
  <Agents locale={locale} data={data.agents} agents={agents} />
  <Pricing locale={locale} data={data.pricing} />
  <FAQ data={data.faq} />
  <Footer data={data.footer} />
</Base>
